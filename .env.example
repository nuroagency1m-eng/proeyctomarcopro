# ============================================================
# VIRTUS PLATFORM — PLANTILLA DE VARIABLES DE ENTORNO
# ============================================================
# Copia este archivo como .env y completa los valores reales.
#   cp .env.example .env
#
# ⚠️  NUNCA pongas valores reales en este archivo.
#     Este archivo SÍ se sube a GitHub.
# ============================================================

# ------------------------------------------------------------
# BASE DE DATOS — Supabase PostgreSQL
# Obtener en: https://supabase.com/dashboard → Settings → Database
# ------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROYECTO_ID.supabase.co:5432/postgres?sslmode=require"

# ------------------------------------------------------------
# SUPABASE — Storage & API
# Obtener en: https://supabase.com/dashboard → Settings → API
# ------------------------------------------------------------
SUPABASE_URL="https://TU_PROYECTO.supabase.co"
SUPABASE_ANON_KEY="tu_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="tu_supabase_service_role_key"

# ------------------------------------------------------------
# AUTENTICACIÓN — JWT
# Generar con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ------------------------------------------------------------
JWT_SECRET="minimo-64-caracteres-aleatorios-aqui"

# ------------------------------------------------------------
# URL DE LA APLICACIÓN
# Local: http://localhost:3000
# Producción: https://tudominio.com
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
BASE_URL="http://localhost:3000"

# ------------------------------------------------------------
# EMAIL — Gmail SMTP
# Obtener en: Cuenta Google → Seguridad → Contraseñas de aplicación
# Requiere verificación en 2 pasos activada.
# ------------------------------------------------------------
GMAIL_USER="tu_correo@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# ------------------------------------------------------------
# CIFRADO — WhatsApp Bot
# ⚠️  Generar UNA VEZ y NUNCA cambiar después del primer uso.
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ------------------------------------------------------------
ENCRYPTION_KEY="32_caracteres_hexadecimales_aqui"

# ------------------------------------------------------------
# CIFRADO — Ads
# Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ------------------------------------------------------------
ADS_ENCRYPTION_KEY="clave_aes256_en_base64_aqui"

# ------------------------------------------------------------
# META ADS — Facebook / Instagram
# Obtener en: https://developers.facebook.com → Tu App → Settings → Basic
# ------------------------------------------------------------
NEXT_PUBLIC_META_APP_ID="tu_meta_app_id"
META_APP_ID="tu_meta_app_id"
META_APP_SECRET="tu_meta_app_secret"
META_REDIRECT_URI="http://localhost:3000/api/ads/integrations/meta/connect/callback"
META_CLIPPING_REDIRECT_URI="http://localhost:3000/api/clipping/oauth/facebook/callback"

# ------------------------------------------------------------
# GOOGLE ADS
# Obtener en: https://console.cloud.google.com → APIs & Services → Credentials
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/ads/integrations/google_ads/connect/callback"
GOOGLE_DEVELOPER_TOKEN=""

# ------------------------------------------------------------
# TIKTOK ADS
# Obtener en: https://ads.tiktok.com/marketing_api/apps/
# ------------------------------------------------------------
TIKTOK_APP_ID=""
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
TIKTOK_REDIRECT_URI="http://localhost:3000/api/ads/integrations/tiktok/connect/callback"

# CRON JOBS
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="clave-aleatoria-para-proteger-endpoints-de-cron"

# OPENAI — cada usuario configura su propia clave desde Dashboard → Bots → Credenciales
# YCLOUD / WHATSAPP — cada bot tiene su propia clave guardada cifrada en la DB

# ------------------------------------------------------------
# Web Push (VAPID)
# Generar con: npx web-push generate-vapid-keys
# ------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:soporte@tudominio.com"

# ------------------------------------------------------------
# SOCIAL OAUTH — Redirects para conexiones de redes sociales
# ------------------------------------------------------------
SOCIAL_FACEBOOK_REDIRECT_URI="http://localhost:3000/api/social/oauth/facebook"
SOCIAL_TIKTOK_REDIRECT_URI="http://localhost:3000/api/social/oauth/tiktok"

# ------------------------------------------------------------
# YOUTUBE
# Obtener en: https://console.cloud.google.com → APIs → YouTube Data API v3
# ------------------------------------------------------------
YOUTUBE_API_KEY=""
YOUTUBE_REDIRECT_URI="http://localhost:3000/api/social/oauth/youtube"

# ------------------------------------------------------------
# CLOUDFLARE TURNSTILE (anti-bot / CAPTCHA)
# Obtener en: https://dash.cloudflare.com → Turnstile → Add site
# ------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
